{
  "name": "mars",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:check": "turbo lint:check",
    "format": "prettier --write \"**/*.{ts,tsx,json}\"",

    "version:server:patch": "cd apps/server && npm version patch --no-git-tag-version",
    "version:server:minor": "cd apps/server && npm version minor --no-git-tag-version",
    "version:server:major": "cd apps/server && npm version major --no-git-tag-version",

    "version:web:patch": "cd apps/web && npm version patch --no-git-tag-version",
    "version:web:minor": "cd apps/web && npm version minor --no-git-tag-version",
    "version:web:major": "cd apps/web && npm version major --no-git-tag-version",

    "version:all:patch": "npm version patch --no-git-tag-version --prefix apps/server && npm version patch --no-git-tag-version --prefix apps/web",
    "version:all:minor": "npm version minor --no-git-tag-version --prefix apps/server && npm version minor --no-git-tag-version --prefix apps/web",
    "version:all:major": "npm version major --no-git-tag-version --prefix apps/server && npm version major --no-git-tag-version --prefix apps/web",

    "release:all:patch": "bash scripts/release.sh all patch",
    "release:all:minor": "bash scripts/release.sh all minor",
    "release:all:major": "bash scripts/release.sh all major",

    "release:server:patch": "bash scripts/release.sh server patch",
    "release:server:minor": "bash scripts/release.sh server minor",
    "release:server:major": "bash scripts/release.sh server major",

    "release:web:patch": "bash scripts/release.sh web patch",
    "release:web:minor": "bash scripts/release.sh web minor",
    "release:web:major": "bash scripts/release.sh web major"
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.12.4",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "@prisma/engines", "prisma", "@nestjs/core", "unrs-resolver"]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
