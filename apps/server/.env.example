# Mars Server 环境变量模板
# 复制此文件为 .env 并填入真实值
# .env 已在 .gitignore 中，不会被提交到 Git

# 数据库连接
DATABASE_URL="mysql://root:root123@localhost:3306/mars"

# 飞书 OAuth 应用凭证（从 GitHub Secrets 获取）
FEISHU_APP_ID=your_feishu_app_id_here
FEISHU_APP_SECRET=your_feishu_app_secret_here
FEISHU_REDIRECT_URI=http://localhost:3000/auth
FEISHU_REDIRECT_URI_TERRA=http://localhost:3001/auth

# JWT
JWT_SECRET=change-me-in-production

# CronFlow 服务地址
CRONFLOW_URL=http://localhost:4001
