generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model BusinessOrder {
  id        BigInt   @id @default(autoincrement())
  title     String   @db.VarChar(255)
  content   String?  @db.Text
  status    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("business_orders")
}

model CronConfig {
  id         BigInt   @id @default(autoincrement())
  name       String   @db.VarChar(255)
  cronExpr   String   @map("cron_expr") @db.VarChar(100)
  taskType   String   @map("task_type") @db.VarChar(50)
  taskParams String?  @map("task_params") @db.Text
  status     Int      @default(1)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  logs CronExecutionLog[]

  @@map("cron_configs")
}

model CronExecutionLog {
  id        BigInt   @id @default(autoincrement())
  configId  BigInt   @map("config_id")
  startTime DateTime @map("start_time")
  endTime   DateTime? @map("end_time")
  status    Int?
  errorMsg  String?  @map("error_msg") @db.Text
  env       String   @default("dev") @db.VarChar(10)
  createdAt DateTime @default(now()) @map("created_at")

  config CronConfig @relation(fields: [configId], references: [id])

  @@map("cron_execution_logs")
}

// ============================================================
// Novel Module (metadata only - content stored in IndexedDB)
// ============================================================

model Novel {
  id          BigInt   @id @default(autoincrement())
  openId      String   @map("open_id") @db.VarChar(255)
  title       String   @db.VarChar(500)
  genre       String?  @db.VarChar(100)
  description String?  @db.Text
  coverUrl    String?  @map("cover_url") @db.VarChar(500)
  wordCount   Int      @default(0) @map("word_count")
  status      Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  chapters NovelChapter[]

  @@map("novels")
}

model NovelChapter {
  id           BigInt   @id @default(autoincrement())
  novelId      BigInt   @map("novel_id")
  title        String   @db.VarChar(500)
  chapterOrder Int      @default(0) @map("chapter_order")
  wordCount    Int      @default(0) @map("word_count")
  status       Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@map("novel_chapters")
}

// ============================================================
// AI Credit Module
// ============================================================

model CreditPackage {
  id          BigInt   @id @default(autoincrement())
  name        String   @db.VarChar(255)
  description String?  @db.Text
  points      Int
  priceCent   Int      @map("price_cent")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  orders CreditOrder[]

  @@map("credit_packages")
}

model UserCredit {
  id          BigInt   @id @default(autoincrement())
  openId      String   @unique @map("open_id") @db.VarChar(255)
  balance     Int      @default(0)
  totalEarned Int      @default(0) @map("total_earned")
  totalSpent  Int      @default(0) @map("total_spent")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("user_credits")
}

model CreditOrder {
  id            BigInt    @id @default(autoincrement())
  openId        String    @map("open_id") @db.VarChar(255)
  packageId     BigInt    @map("package_id")
  points        Int
  amountCent    Int       @map("amount_cent")
  status        Int       @default(0)
  paidAt        DateTime? @map("paid_at")
  paymentMethod String?   @map("payment_method") @db.VarChar(50)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  package CreditPackage @relation(fields: [packageId], references: [id])

  @@map("credit_orders")
}

model CreditUsageLog {
  id           BigInt   @id @default(autoincrement())
  openId       String   @map("open_id") @db.VarChar(255)
  points       Int
  balanceAfter Int      @map("balance_after")
  action       String   @db.VarChar(50)
  refId        String?  @map("ref_id") @db.VarChar(255)
  metadata     String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([openId])
  @@map("credit_usage_logs")
}

model AiModelConfig {
  id           BigInt   @id @default(autoincrement())
  modelKey     String   @unique @map("model_key") @db.VarChar(100)
  displayName  String   @map("display_name") @db.VarChar(255)
  provider     String   @db.VarChar(50)
  costPerCall  Int      @map("cost_per_call")
  costPerToken Int      @default(0) @map("cost_per_token")
  maxTokens    Int      @default(4096) @map("max_tokens")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("ai_model_configs")
}

// ============================================================
// User Data Sync (full snapshot stored as JSON)
// ============================================================

model UserDataSync {
  id        BigInt   @id @default(autoincrement())
  openId    String   @unique @map("open_id") @db.VarChar(255)
  syncData  String   @map("sync_data") @db.MediumText
  syncedAt  DateTime @default(now()) @map("synced_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("user_data_sync")
}

